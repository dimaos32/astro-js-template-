{
  "name": "astro-js-template",
  "version": "0.0.3",
  "type": "module",
  "description": "Современный шаблон для верстки на Astro с SCSS",
  "author": "Dmitrii Osadchenko <osadchenko.d@gmail.com>",
  "repository": "github:dimaos32/astro-js-template",
  "homepage": "https://github.com/dimaos32/astro-js-template",
  "bugs": "https://github.com/dimaos32/astro-js-template/issues",
  "license": "MIT",
  "keywords": [
    "astro",
    "template",
    "scss",
    "frontend",
    "boilerplate",
    "starter-kit"
  ],
  "browserslist": [
    "last 6 versions",
    "not dead",
    "not op_mini all",
    "Safari >= 15.4",
    "Firefox ESR"
  ],
  "scripts": {
    "dev": "astro dev",
    "build": "npm run lint && astro build",
    "preview": "astro preview",
    "gen:sprite": "node utils/generate-sprite.mjs",
    "lint:js": "eslint . --ext .js,.astro",
    "lint:css": "stylelint 'src/**/*.scss'",
    "lint": "npm run lint:js && npm run lint:css",
    "proc:images": "node ./utils/optimize-images.mjs"
  },
  "dependencies": {
    "-": "^0.0.1",
    "@csstools/normalize.css": "^12.1.1",
    "@fluejs/noscroll": "^1.0.0",
    "astro": "^5.17.1",
    "chalk": "^5.6.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@moritzloewenstein/vite-plugin-sass-glob-import": "^6.0.3",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.0.2",
    "eslint-plugin-astro": "^1.6.0",
    "globals": "^17.3.0",
    "inquirer": "^13.3.0",
    "p-limit": "^7.3.0",
    "postcss": "^8.5.6",
    "postcss-combine-media-query": "^2.1.0",
    "postcss-preset-env": "^11.2.0",
    "postcss-pxtorem": "^6.1.0",
    "postcss-sort-media-queries": "^5.2.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "sass": "^1.97.3",
    "sharp": "^0.34.5",
    "stylelint": "^17.4.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-scss": "^7.0.0",
    "svgo": "^4.0.1"
  }
}
